{
  "name": "web-solid",
  "version": "0.1.0",
  "description": "Personal site built with SolidStart",
  "engines": {
    "node": ">=24"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build.types": "tsc --incremental --noEmit",
    "dev": "STAGE_NAME=dev vite dev",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"{src,openapi,tests}/**/*.ts*\" \"*.config.ts\"",
    "preview": "STAGE_NAME=dev vite preview --open",
    "start": "STAGE_NAME=dev vite preview",
    "pretest": "pnpm run build",
    "test": "pnpm run test.unit && pnpm run test.ssr",
    "test.unit": "vitest run src openapi",
    "test.ssr": "vitest run tests/ssr.spec.ts",
    "predeploy": "pnpm run build",
    "deploy": "./scripts/deploy-s3.sh && ./scripts/deploy-lambda.sh",
    "deploy.dev": "STAGE_NAME=dev pnpm run deploy",
    "deploy.stg": "STAGE_NAME=stg pnpm run deploy",
    "deploy.prod": "STAGE_NAME=prod pnpm run deploy",
    "postdeploy": "./scripts/invalidate.sh",
    "stylelint": "stylelint './src/**/*.scss' './src/**/*.css'",
    "generate:openapi": "openapi-typescript http://dev-www.ikuma.cloud/api/v2/openapi.json -o openapi/schema.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@solidjs/testing-library": "0.8.10",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.0.14",
    "@types/three": "^0.184.1",
    "eslint": "^9.37.0",
    "eslint-plugin-solid": "0.14.5",
    "globals": "16.4.0",
    "openapi-typescript": "^7.9.1",
    "prettier": "3.6.2",
    "schema-dts": "^1.1.5",
    "stylelint": "^16.17.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "typescript": "5.8",
    "typescript-eslint": "8.38.0",
    "typescript-plugin-css-modules": "latest",
    "vite": "8.1.5",
    "vite-plugin-solid": "2.11.13",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@elmethis/solid": "0.3.1",
    "@mdi/js": "^7.4.47",
    "@solid-primitives/i18n": "2.2.1",
    "@solidjs/meta": "0.29.4",
    "@solidjs/router": "0.16.2",
    "@solidjs/start": "2.0.0-beta.9",
    "fuse.js": "^7.1.0",
    "nitro": "3.0.260610-beta",
    "shiki": "4.3.1",
    "sitemap": "^9.0.0",
    "solid-js": "1.9.14",
    "three": "^0.184.0"
  }
}
